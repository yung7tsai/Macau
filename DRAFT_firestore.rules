rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // No mass scraping
      allow create: if isOwner(userId) 
        && incoming().keys().hasAll(['displayName', 'email'])
        && incoming().displayName is string
        && incoming().email is string;
      allow update: if isOwner(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // --- Trips Collection ---
    match /trips/{tripId} {
      function isValidTrip(data) {
        return data.name is string && data.name.size() <= 100
          && data.startDate is string
          && data.endDate is string
          && data.ownerId == request.auth.uid;
      }

      allow get: if isSignedIn(); // Basic read, restricted by list logic
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidTrip(incoming()) && isValidId(tripId);
      allow update: if isOwner(existing().ownerId) && isValidTrip(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'startDate', 'endDate', 'participants']);
      allow delete: if isOwner(existing().ownerId);

      // --- Subcollections ---
      
      match /itinerary/{itemId} {
        function isValidItem(data) {
          return data.title is string && data.title.size() <= 200
            && data.dayIndex is int
            && data.type in ['attraction', 'restaurant', 'transport', 'flight', 'checkin', 'other'];
        }

        allow read: if isSignedIn(); // Parent access checked in list
        allow list: if isSignedIn(); // Usually queried under trip
        
        allow create: if isSignedIn() && isValidItem(incoming()) && isValidId(itemId);
        allow update: if isSignedIn() && isValidItem(incoming());
        allow delete: if isSignedIn();
      }

      match /expenses/{expenseId} {
        function isValidExpense(data) {
          return data.description is string && data.description.size() <= 200
            && data.amount is number
            && data.date is string;
        }

        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && isValidExpense(incoming()) && isValidId(expenseId);
        allow update: if isSignedIn() && isValidExpense(incoming());
        allow delete: if isSignedIn();
      }

      match /quickInfo/{infoId} {
        allow read, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }
  }
}
